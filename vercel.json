{
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "node tools/prerender-static.mjs",
  "redirects": [
    { "source": "/pages/experiments", "destination": "/pages/index-ventures", "permanent": true },
    { "source": "/pages/experiments.html", "destination": "/pages/index-ventures", "permanent": true },
    { "source": "/Flits.html", "destination": "/", "permanent": true },
    { "source": "/Flits", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/content/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/assets/(.*).md",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
